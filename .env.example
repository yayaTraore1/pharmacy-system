# ===== BASE DE DONNÉES =====
# Format: postgresql://user:password@hostname:5432/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/pharmacie_db

# ===== SÉCURITÉ =====
# Générer une clé secrète forte : openssl rand -hex 32
SECRET_KEY=your_long_random_secret_here

# Algorithme JWT
ALGORITHM=HS256

# Durée d'expiration du token (en minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== OPTIONNEL =====
# Pour le débogage
DEBUG=False

# Hôte et port
HOST=0.0.0.0
PORT=8000

# BASE URL
BASE_URL=http://127.0.0.1:8000

# SMTP (exemple)
SMTP_USER=you@example.com
SMTP_PASSWORD=your_smtp_password_here
# ===== BASE DE DONNÉES =====
# Pour le déploiement sur Render, utilise l'URL fournie par Render
# Format: postgresql://user:password@hostname:5432/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/pharmacie_db

# ===== SÉCURITÉ =====
# Générer une clé secrète forte : openssl rand -hex 32
SECRET_KEY=votre_clé_secrète_super_longue_et_aléatoire_ici

# Algorithme JWT
ALGORITHM=HS256

# Durée d'expiration du token (en minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== OPTIONNEL =====
# Pour le débogage
DEBUG=False

# Hôte et port (ignorés sur Render, qui utilise $PORT)
HOST=0.0.0.0
PORT=8000
